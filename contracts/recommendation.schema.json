{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sethiramicrosoft.github.io/azure-copilot-finops-starter/contracts/recommendation.schema.json",
  "title": "FinOpsRecommendation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recommendationId",
    "scope",
    "category",
    "summary",
    "evidence",
    "risk",
    "approvalRequired",
    "createdAt"
  ],
  "properties": {
    "recommendationId": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scopeType", "scopeId"],
      "properties": {
        "scopeType": {
          "type": "string",
          "enum": ["managementGroup", "subscription", "resourceGroup", "resource", "billingProfile"]
        },
        "scopeId": { "type": "string", "minLength": 1 }
      }
    },
    "category": {
      "type": "string",
      "enum": ["anomaly", "budgetRisk", "rightsizing", "commitment", "policy", "forecast", "other"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "estimatedImpact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "amount"],
      "properties": {
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
        "amount": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "reference"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "reference": { "type": "string", "minLength": 1 }
        }
      }
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "approvalRequired": { "type": "boolean", "const": true },
    "proposedAction": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
