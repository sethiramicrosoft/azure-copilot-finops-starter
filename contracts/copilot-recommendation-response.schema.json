{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sethiramicrosoft.github.io/azure-copilot-finops-starter/contracts/copilot-recommendation-response.schema.json",
  "title": "CopilotRecommendationResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recommendationId",
    "summary",
    "proposedAction",
    "risk",
    "estimatedImpact",
    "approvalRequired",
    "allowAutomaticMutation",
    "evidenceRefs"
  ],
  "properties": {
    "recommendationId": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "proposedAction": { "type": "string", "minLength": 1 },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "estimatedImpact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "amount", "confidence"],
      "properties": {
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
        "amount": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "approvalRequired": { "type": "boolean", "const": true },
    "allowAutomaticMutation": { "type": "boolean", "const": false },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "personaSummary": { "type": "string" }
  }
}
