# Runtime mode
TRACKER_MODE=memory
LEDGER_FILE_PATH=data/action-ledger.jsonl

# GitHub Issues adapter (TRACKER_MODE=github)
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-repo
GITHUB_TOKEN_ENV=GITHUB_TOKEN
# export GITHUB_TOKEN in local runtime only

# Jira adapter (TRACKER_MODE=jira)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=you@company.com
JIRA_PROJECT_KEY=OPS
JIRA_TOKEN_ENV=JIRA_API_TOKEN
JIRA_TRANSITION_MAP_JSON={"new":"11","triaged":"21","approved":"31","authorized":"41","inProgress":"51","resolved":"61","dismissed":"71","closed":"81","needsMoreEvidence":"91"}
# export JIRA_API_TOKEN in local runtime only

# Azure DevOps adapter (TRACKER_MODE=ado)
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PROJECT=your-project
ADO_PAT_ENV=AZDO_PAT
# export AZDO_PAT in local runtime only
